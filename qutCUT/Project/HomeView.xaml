<UserControl
    x:Class="qutCUT.Project.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource AppBgPrimary}" Padding="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16">
            <TextBlock Text="qutCUT"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource AppTextPrimary}"/>
            <Border Background="{StaticResource AppAccent}"
                    CornerRadius="4" Padding="8,2">
                <TextBlock Text="AI Video Editor" FontSize="11"
                           Foreground="White"/>
            </Border>
        </StackPanel>

        <!-- Actions row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">
            <Button x:Name="NewProjectBtn" Content="New Project"
                    Click="OnNewProject"
                    Background="{StaticResource AppAccent}"
                    Foreground="White"
                    CornerRadius="6" Padding="16,8"/>
            <Button x:Name="OpenProjectBtn" Content="Open…"
                    Click="OnOpenProject"
                    Background="{StaticResource AppBgTertiary}"
                    Foreground="{StaticResource AppTextPrimary}"
                    CornerRadius="6" Padding="16,8"/>
        </StackPanel>

        <!-- Recent projects -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Recent"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource AppTextSecondary}"
                       Margin="0,0,0,16"/>

            <ItemsControl x:Name="RecentList" ItemsSource="{x:Bind Recent}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:RecentProject">
                        <Button Click="OnOpenRecent" Tag="{x:Bind FilePath}"
                                HorizontalAlignment="Stretch"
                                Background="{StaticResource AppBgSecondary}"
                                CornerRadius="8" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="{x:Bind Name}"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="{StaticResource AppTextPrimary}"/>
                                <TextBlock Text="{x:Bind FilePath}"
                                           FontSize="11"
                                           Foreground="{StaticResource AppTextTertiary}"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
