<ContentDialog
    x:Class="qutCUT.Export.ExportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Export"
    PrimaryButtonText="Export"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <StackPanel Spacing="16" Width="360">

        <!-- Format -->
        <StackPanel Spacing="6">
            <TextBlock Text="Format" FontSize="12" FontWeight="Medium"
                       Foreground="{StaticResource AppTextPrimary}"/>
            <ComboBox x:Name="FormatPicker" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="H.264 (MP4)" IsSelected="True"/>
                <ComboBoxItem Content="H.265 / HEVC (MP4)"/>
                <ComboBoxItem Content="Apple ProRes (MOV)"/>
            </ComboBox>
        </StackPanel>

        <!-- Resolution -->
        <StackPanel Spacing="6">
            <TextBlock Text="Resolution" FontSize="12" FontWeight="Medium"
                       Foreground="{StaticResource AppTextPrimary}"/>
            <ComboBox x:Name="ResolutionPicker" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="720p"/>
                <ComboBoxItem Content="1080p" IsSelected="True"/>
                <ComboBoxItem Content="4K"/>
            </ComboBox>
        </StackPanel>

        <!-- Output path -->
        <StackPanel Spacing="6">
            <TextBlock Text="Output" FontSize="12" FontWeight="Medium"
                       Foreground="{StaticResource AppTextPrimary}"/>
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="OutputPath" IsReadOnly="True"
                         PlaceholderText="Choose output file…"/>
                <Button Grid.Column="1" Content="…" Click="OnBrowse"/>
            </Grid>
        </StackPanel>

        <!-- Progress -->
        <ProgressBar x:Name="ExportProgress"
                     Visibility="{x:Bind IsExporting, Mode=OneWay}"
                     Value="{x:Bind ExportProgressValue, Mode=OneWay}"
                     Minimum="0" Maximum="100"/>

        <TextBlock x:Name="StatusText"
                   Text="{x:Bind StatusMessage, Mode=OneWay}"
                   FontSize="11"
                   Foreground="{StaticResource AppTextTertiary}"
                   Visibility="{x:Bind IsExporting, Mode=OneWay}"/>
    </StackPanel>
</ContentDialog>
