<UserControl
    x:Class="qutCUT.Inspector.InspectorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource AppBgSecondary}"
            BorderBrush="{StaticResource AppBorderSubtle}"
            BorderThickness="1,0,0,0">
        <ScrollViewer>
            <StackPanel Padding="16" Spacing="16"
                        Visibility="{x:Bind HasSelection, Mode=OneWay}">

                <!-- Transform section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="TRANSFORM" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextTertiary}"
                               CharacterSpacing="100"/>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="X" FontSize="10" Foreground="{StaticResource AppTextTertiary}"/>
                            <NumberBox x:Name="TransformX" SpinButtonPlacementMode="Inline"
                                       ValueChanged="OnTransformXChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Y" FontSize="10" Foreground="{StaticResource AppTextTertiary}"/>
                            <NumberBox x:Name="TransformY" SpinButtonPlacementMode="Inline"
                                       ValueChanged="OnTransformYChanged"/>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Scale X" FontSize="10" Foreground="{StaticResource AppTextTertiary}"/>
                            <NumberBox x:Name="ScaleX" Minimum="0.01" Maximum="10"
                                       SmallChange="0.01" LargeChange="0.1"
                                       SpinButtonPlacementMode="Inline"
                                       ValueChanged="OnScaleXChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Scale Y" FontSize="10" Foreground="{StaticResource AppTextTertiary}"/>
                            <NumberBox x:Name="ScaleY" Minimum="0.01" Maximum="10"
                                       SmallChange="0.01" LargeChange="0.1"
                                       SpinButtonPlacementMode="Inline"
                                       ValueChanged="OnScaleYChanged"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Rotation" FontSize="10" Foreground="{StaticResource AppTextTertiary}"/>
                        <NumberBox x:Name="RotationBox" Minimum="-180" Maximum="180"
                                   SpinButtonPlacementMode="Inline"
                                   ValueChanged="OnRotationChanged"/>
                    </StackPanel>
                </StackPanel>

                <!-- Divider -->
                <Rectangle Height="0.5" Fill="{StaticResource AppBorderSubtle}"/>

                <!-- Opacity & Volume section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="COMPOSITING" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextTertiary}"
                               CharacterSpacing="100"/>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Opacity" FontSize="10" Foreground="{StaticResource AppTextTertiary}"/>
                        <Slider x:Name="OpacitySlider" Minimum="0" Maximum="1" StepFrequency="0.01"
                                ValueChanged="OnOpacityChanged"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Volume" FontSize="10" Foreground="{StaticResource AppTextTertiary}"/>
                        <Slider x:Name="VolumeSlider" Minimum="0" Maximum="2" StepFrequency="0.01"
                                ValueChanged="OnVolumeChanged"/>
                    </StackPanel>
                </StackPanel>

                <!-- Divider -->
                <Rectangle Height="0.5" Fill="{StaticResource AppBorderSubtle}"/>

                <!-- Speed section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="SPEED" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextTertiary}"
                               CharacterSpacing="100"/>
                    <NumberBox x:Name="SpeedBox" Minimum="0.1" Maximum="16"
                               SmallChange="0.1"
                               SpinButtonPlacementMode="Inline"
                               ValueChanged="OnSpeedChanged"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
